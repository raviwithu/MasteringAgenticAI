# LLM for entity generation. Without a key, the pipeline still ingests, retrieves,
# reranks, and stores the retrieved context as a placeholder description.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — override the source folder (defaults to ../Data/Linux).
# LINUX_DATA_DIR=/absolute/path/to/Week 2/Data/Linux
