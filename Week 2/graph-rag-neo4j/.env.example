# Neo4j connection (defaults match the local Docker command in the README).
# Point these at a Neo4j Aura instance to use the cloud instead.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag-demo-pw

# Optional — enables the final LLM answer step. Leave blank to skip it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — override book auto-discovery (defaults to ../../Reference/Books).
# REFERENCE_BOOKS_DIR=/absolute/path/to/Books
