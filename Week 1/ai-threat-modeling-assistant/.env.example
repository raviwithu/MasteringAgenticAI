# Copy to .env and fill in. .env should never be committed.

# Your OpenAI API key. Leave blank to run in mock mode (no key needed).
OPENAI_API_KEY=

# Model used when an API key is present. In OpenAI mode the "Generate" button
# runs a LangChain tool-calling agent, so this MUST support tool calling
# (gpt-4o-mini / gpt-4.1-mini both do).
OPENAI_MODEL=gpt-4o-mini

# Force the built-in offline mock LLM regardless of the key above.
# "true" = always mock; "false"/blank = use OpenAI when a key is set.
USE_MOCK_LLM=true

# --- Reference knowledge base (threat-modeling books → ChromaDB) ---
# Folder with the PDF books. If unset, the app searches up for a Reference/Books dir.
# REFERENCE_BOOKS_DIR=/workspaces/VS/Reference/Books
# Local embedding model (GPU auto-detected). Leave EMBEDDING_DEVICE blank for auto.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=128
# REFERENCE_TOP_K=5
