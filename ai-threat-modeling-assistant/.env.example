# Copy to .env and fill in. .env should never be committed.

# Your OpenAI API key. Leave blank to run in mock mode (no key needed).
OPENAI_API_KEY=

# Model used when an API key is present.
OPENAI_MODEL=gpt-4o-mini

# Force the built-in offline mock LLM regardless of the key above.
# "true" = always mock; "false"/blank = use OpenAI when a key is set.
USE_MOCK_LLM=true
